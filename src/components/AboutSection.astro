---
import { Icon } from 'astro-icon/components';
import { t, type Lang } from '../lib/i18n';
import TechBadge from './TechBadge.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

type SkillItem = string | { label: string; note: string };
interface SkillGroup {
  key: string;
  icon: string;
  items: SkillItem[];
}

const skillGroups: SkillGroup[] = [
  { key: 'data', icon: 'lucide:brain', items: ['Python', 'pandas', 'NumPy', 'scikit-learn', 'PyTorch', 'Darts', 'AutoTS', 'Jupyter'] },
  { key: 'enterprise', icon: 'lucide:building-2', items: ['SAP Test Automation', 'Tricentis TOSCA', 'Jira', 'Agile / Scrum'] },
  { key: 'web', icon: 'lucide:monitor', items: ['JavaScript', 'React', 'HTML/CSS'] },
  { key: 'backend', icon: 'lucide:server', items: ['Java', 'Node.js', 'REST', 'MySQL', 'MongoDB', { label: 'Go', note: 'about.skills.note.learning' }] },
  { key: 'devops', icon: 'lucide:cloud', items: ['Linux', 'Git', 'Bash', 'GitHub Actions', 'AWS', { label: 'Docker', note: 'about.skills.note.learning' }, { label: 'Kubernetes', note: 'about.skills.note.learning' }] },
];
---

<section class="container-prose py-16 border-t border-[var(--color-border)]">
  <h2 class="text-3xl sm:text-4xl font-bold mb-8">{t('about.title', lang)}</h2>

  <div class="space-y-4 text-base sm:text-lg text-[var(--color-fg-muted)] leading-relaxed mb-12">
    <p>{t('about.body', lang)}</p>
  </div>

  <h3 class="text-xl font-semibold mb-6">{t('about.skills', lang)}</h3>

  <div class="grid sm:grid-cols-2 gap-6">
    {
      skillGroups.map(({ key, icon, items }) => (
        <div class="p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]/50">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
              <Icon name={icon} class="h-4 w-4" />
            </span>
            <h4 class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-dim)]">
              {t(`about.skills.${key}`, lang)}
            </h4>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {items.map((item) =>
              typeof item === 'string' ? (
                <TechBadge label={item} />
              ) : (
                <span class="inline-flex items-center gap-1.5">
                  <TechBadge label={item.label} />
                  <span class="text-[10px] font-mono uppercase tracking-wider text-[var(--color-fg-dim)]">
                    {t(item.note, lang)}
                  </span>
                </span>
              )
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>
