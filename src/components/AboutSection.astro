---
import { Icon } from 'astro-icon/components';
import { t, type Lang } from '../lib/i18n';
import TechBadge from './TechBadge.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const skillGroups = [
  { key: 'devops', icon: 'lucide:cloud', items: ['Kubernetes', 'ArgoCD', 'Helm', 'Docker', 'GitHub Actions', 'Terraform', 'kind', 'Linux'] },
  { key: 'data', icon: 'lucide:brain', items: ['Python', 'PyTorch', 'scikit-learn', 'Darts', 'LightGBM', 'pandas', 'NumPy', 'Jupyter'] },
  { key: 'backend', icon: 'lucide:server', items: ['Go', 'Node.js', 'MongoDB', 'REST', 'Java'] },
  { key: 'frontend', icon: 'lucide:monitor', items: ['TypeScript', 'Astro', 'React', 'Tailwind', 'HTML/CSS'] },
];
---

<section class="container-prose py-16 border-t border-[var(--color-border)]">
  <h2 class="text-3xl sm:text-4xl font-bold mb-8">{t('about.title', lang)}</h2>

  <div class="space-y-4 text-base sm:text-lg text-[var(--color-fg-muted)] leading-relaxed mb-12">
    <p>{t('about.body', lang)}</p>
    <p>{t('about.body.search', lang)}</p>
  </div>

  <h3 class="text-xl font-semibold mb-6">{t('about.skills', lang)}</h3>

  <div class="grid sm:grid-cols-2 gap-6">
    {
      skillGroups.map(({ key, icon, items }) => (
        <div class="p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]/50">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
              <Icon name={icon} class="h-4 w-4" />
            </span>
            <h4 class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-dim)]">
              {t(`about.skills.${key}`, lang)}
            </h4>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {items.map((skill) => <TechBadge label={skill} />)}
          </div>
        </div>
      ))
    }
  </div>
</section>
