---
import { t, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
  <div class="container-wide py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm text-[var(--color-fg-muted)]">
    <div class="flex flex-col gap-1">
      <span>© {year} {t('footer.copyright', lang)}</span>
      <span class="text-xs text-[var(--color-fg-dim)]">
        {t('footer.builtWith', lang)} <a class="hover:text-[var(--color-accent)]" href="https://astro.build" target="_blank" rel="noopener">Astro</a> · <a class="hover:text-[var(--color-accent)]" href="https://tailwindcss.com" target="_blank" rel="noopener">Tailwind</a>
      </span>
    </div>

    <div class="flex items-center gap-4">
      <a
        href="https://github.com/Spla4sH"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 hover:text-[var(--color-accent)]"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.14.08 1.74 1.17 1.74 1.17 1.02 1.74 2.67 1.24 3.32.94.1-.74.4-1.24.72-1.52-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.07 11.07 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <a
        href="mailto:sebastian.roesch92@gmail.com"
        class="inline-flex items-center gap-2 hover:text-[var(--color-accent)]"
        aria-label="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="hidden sm:inline">Email</span>
      </a>
      <a
        href="https://github.com/Spla4sH/spla4sh.github.io"
        target="_blank"
        rel="noopener"
        class="hover:text-[var(--color-accent)]"
      >
        {t('footer.viewSource', lang)}
      </a>
    </div>
  </div>
</footer>
