---
import { t, localizedPath, routeNames, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const routes = routeNames[lang];
---

<section class="container-prose pt-12 sm:pt-20 pb-16">
  <div class="flex items-center gap-2 mb-6 fade-up" style="--stagger: 0ms">
    <span class="relative flex h-2.5 w-2.5">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-accent)] opacity-75"></span>
      <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
    </span>
    <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-accent)]">
      {t('hero.openToWork', lang)}
    </span>
  </div>

  <p class="text-[var(--color-fg-muted)] text-base sm:text-lg mb-2 font-mono fade-up" style="--stagger: 80ms">
    {t('hero.greeting', lang)}
  </p>

  <h1
    class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-[var(--color-fg)] mb-6 fade-up"
    style="--stagger: 160ms"
  >
    Sebastian <span class="text-[var(--color-accent)]">Rösch</span>
  </h1>

  <p class="text-lg sm:text-xl text-[var(--color-fg-muted)] font-mono mb-8 tracking-tight fade-up" style="--stagger: 240ms">
    {t('hero.tagline', lang)}
  </p>

  <p class="text-base sm:text-lg text-[var(--color-fg-muted)] leading-relaxed mb-10 max-w-xl fade-up" style="--stagger: 320ms">
    {t('hero.intro', lang)}
  </p>

  <div class="flex flex-wrap items-center gap-3 fade-up" style="--stagger: 400ms">
    <a
      href={localizedPath(routes.projects, lang)}
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-accent)] text-[var(--color-bg)] font-medium hover:bg-[var(--color-accent-hover)] transition-colors"
    >
      {t('hero.viewProjects', lang)}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
    <a
      href="mailto:sebastian.roesch92@gmail.com"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-[var(--color-border-strong)] text-[var(--color-fg)] font-medium hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
    >
      {t('hero.contact', lang)}
    </a>
    <a
      href="https://github.com/Spla4sH"
      target="_blank"
      rel="noopener"
      aria-label="GitHub"
      class="inline-flex items-center justify-center p-2.5 rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.14.08 1.74 1.17 1.74 1.17 1.02 1.74 2.67 1.24 3.32.94.1-.74.4-1.24.72-1.52-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.07 11.07 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
    </a>
  </div>
</section>
