---
import TechBadge from './TechBadge.astro';
import { t, localizedPath, routeNames, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  category: 'devops' | 'ml' | 'data' | 'web' | 'research';
  stack: string[];
  github?: string;
  date: Date;
  featured?: boolean;
  status?: 'wip' | 'done';
}
const { lang, slug, title, description, category, stack, github, date, featured, status = 'done' } = Astro.props;
const routes = routeNames[lang];
const detailHref = `${localizedPath(routes.projects, lang)}/${slug}`;
const year = date.getFullYear();
---

<article
  data-category={category}
  class="project-card group relative flex flex-col gap-4 p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-strong)] transition-colors"
>
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs font-mono uppercase tracking-wider text-[var(--color-fg-dim)] mb-2">
        {t(`projects.filter.${category}`, lang)} · {year}
      </p>
      <h3 class="text-xl font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors">
        <a href={detailHref} class="after:absolute after:inset-0">
          {title}
        </a>
      </h3>
    </div>
    {
      status === 'wip' ? (
        <span class="shrink-0 px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded border border-amber-500/40 bg-amber-500/10 text-amber-400">
          {t('projects.status.wip', lang)}
        </span>
      ) : (
        featured && (
          <span class="shrink-0 px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
            Featured
          </span>
        )
      )
    }
  </div>

  <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed flex-1">{description}</p>

  {
    stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {stack.slice(0, 6).map((s) => <TechBadge label={s} />)}
      </div>
    )
  }

  {
    github && (
      <div class="flex items-center gap-1 text-xs text-[var(--color-fg-dim)] relative z-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.14.08 1.74 1.17 1.74 1.17 1.02 1.74 2.67 1.24 3.32.94.1-.74.4-1.24.72-1.52-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.07 11.07 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
        <a href={github} target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] relative z-10">
          {github.replace('https://github.com/', '')}
        </a>
      </div>
    )
  }
</article>
