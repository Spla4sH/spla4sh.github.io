---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import TechBadge from '../../components/TechBadge.astro';
import { t } from '../../lib/i18n';
import { experience, education, skills } from '../../data/cv';

const lang = 'de' as const;
const exp = experience[lang];
const edu = education[lang];
const skillGroups = skills[lang];
---

<BaseLayout lang={lang} title={t('cv.title', lang)}>
  <section class="container-prose">
    <div class="flex items-center justify-between mb-12 flex-wrap gap-4">
      <h1 class="text-4xl sm:text-5xl font-bold">{t('cv.title', lang)}</h1>
      <a
        href="/cv-sebastian-roesch-de.pdf"
        download
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border-strong)] text-[var(--color-fg)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        {t('cv.download', lang)}
      </a>
    </div>

    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8">{t('cv.experience', lang)}</h2>
      <div>
        {exp.map((entry) => <TimelineItem {...entry} />)}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8">{t('cv.education', lang)}</h2>
      <div>
        {edu.map((entry) => <TimelineItem {...entry} />)}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8">{t('cv.skills', lang)}</h2>
      <div class="space-y-6">
        {
          skillGroups.map((group) => (
            <div>
              <h3 class="text-sm font-mono uppercase tracking-wider text-[var(--color-fg-dim)] mb-3">
                {group.category}
              </h3>
              <div class="flex flex-wrap gap-1.5">
                {group.items.map((s) => <TechBadge label={s} />)}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-6">{t('cv.languages', lang)}</h2>
      <ul class="space-y-2 text-[var(--color-fg-muted)]">
        <li>{t('cv.languages.german', lang)}</li>
        <li>{t('cv.languages.english', lang)}</li>
      </ul>
    </section>
  </section>
</BaseLayout>
