---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TechBadge from '../../../components/TechBadge.astro';
import { t, localizedPath, routeNames } from '../../../lib/i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (e) => e.data.lang === 'en' && !e.data.draft);
  return projects.map((project) => ({
    params: { slug: project.data.urlSlug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const lang = 'en' as const;
const routes = routeNames[lang];
---

<BaseLayout lang={lang} title={project.data.title} description={project.data.description}>
  <article class="container-prose">
    <a
      href={localizedPath(routes.projects, lang)}
      class="inline-flex items-center text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] mb-8"
    >
      {t('projects.backToList', lang)}
    </a>

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <p class="text-xs font-mono uppercase tracking-wider text-[var(--color-accent)]">
          {t(`projects.filter.${project.data.category}`, lang)}
        </p>
        {
          project.data.status === 'wip' && (
            <span class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded border border-amber-500/40 bg-amber-500/10 text-amber-400">
              {t('projects.status.wip', lang)}
            </span>
          )
        }
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">{project.data.title}</h1>
      <p class="text-lg text-[var(--color-fg-muted)] leading-relaxed mb-6">{project.data.description}</p>
      <div class="flex flex-wrap gap-1.5 mb-6">
        {project.data.stack.map((s: string) => <TechBadge label={s} />)}
      </div>
      {
        project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border-strong)] text-[var(--color-fg)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.14.08 1.74 1.17 1.74 1.17 1.02 1.74 2.67 1.24 3.32.94.1-.74.4-1.24.72-1.52-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.07 11.07 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.05.78 2.12v3.14c0 .31.21.66.8.55A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
            {t('projects.viewOnGithub', lang)}
          </a>
        )
      }
    </header>

    <div class="prose-content text-[var(--color-fg)] leading-relaxed">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-content h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.02em; }
  .prose-content h3 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose-content p { margin-bottom: 1.25rem; color: var(--color-fg-muted); }
  .prose-content ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; color: var(--color-fg-muted); }
  .prose-content ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1.25rem; color: var(--color-fg-muted); }
  .prose-content li { margin-bottom: 0.5rem; }
  .prose-content a { color: var(--color-accent); text-decoration: underline; text-decoration-color: rgba(16, 185, 129, 0.3); text-underline-offset: 3px; }
  .prose-content a:hover { text-decoration-color: var(--color-accent); }
  .prose-content code { background-color: var(--color-surface-2); padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875em; color: var(--color-fg); }
  .prose-content pre { background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1.5rem; }
  .prose-content pre code { background: transparent; padding: 0; }
  .prose-content blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; color: var(--color-fg-muted); margin: 1.5rem 0; font-style: italic; }
  .prose-content strong { color: var(--color-fg); font-weight: 600; }
</style>
