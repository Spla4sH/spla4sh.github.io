---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import ProjectFilter from '../../../components/ProjectFilter.astro';
import { t } from '../../../lib/i18n';

const lang = 'en' as const;
const all = await getCollection('projects', (e) => e.data.lang === lang && !e.data.draft);
const projects = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const uniqueCategories = Array.from(new Set(projects.map((p) => p.data.category)));
---

<BaseLayout lang={lang} title={t('projects.title', lang)}>
  <section class="container-wide">
    <h1 class="text-4xl sm:text-5xl font-bold mb-3">{t('projects.title', lang)}</h1>
    <p class="text-[var(--color-fg-muted)] text-lg mb-10 max-w-2xl">
      {t('projects.subtitle', lang)}
    </p>

    <ProjectFilter lang={lang} categories={uniqueCategories} />

    <div class="grid sm:grid-cols-2 gap-6">
      {
        projects.map((p) => (
          <ProjectCard
            lang={lang}
            slug={p.data.urlSlug}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            stack={p.data.stack}
            github={p.data.github}
            date={p.data.date}
            featured={p.data.featured}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
